{
  "expo": {
    "name": "IONA OS",
    "slug": "iona-os-phone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "iona",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "IONA needs camera access to take photos.",
        "NSMicrophoneUsageDescription": "IONA needs microphone access for video.",
        "NSPhotoLibraryUsageDescription": "IONA needs photo library access to save and view photos.",
        "NSPhotoLibraryAddUsageDescription": "IONA needs to save photos to your library.",
        "NSLocationWhenInUseUsageDescription": "IONA Maps needs your location to show where you are.",
        "NSLocationAlwaysUsageDescription": "IONA uses location for background maps.",
        "NSMotionUsageDescription": "IONA needs motion data for compass heading."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#050505"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.INTERNET",
        "android.permission.BATTERY_STATS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#050505"
        }
      ],
      "expo-secure-store",
      "expo-camera",
      "expo-media-library",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "IONA Maps needs your location.",
          "locationWhenInUsePermission": "IONA Maps needs your location to show where you are."
        }
      ],
      "expo-av",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "IONA uses Face ID to unlock your device."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}